<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/focusguard/db" VERSION="20260711"
    COMMENT="XMLDB file for local_focusguard"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <!-- Campo "blurcount" y no "count": COUNT es palabra/función SQL y las listas de
         campos de la DML de Moodle no siempre la quotean — se evita el riesgo de raíz. -->
    <TABLE NAME="local_focusguard_counts" COMMENT="Focus loss counts per quiz attempt">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="attemptid"    TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK quiz_attempts.id"/>
        <FIELD NAME="userid"       TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="quizid"       TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="blurcount"    TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <!-- UNIQUE en attemptid: upsert por intento (SPECS §2.2). -->
        <KEY NAME="attemptid" TYPE="unique" FIELDS="attemptid"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="quizid" UNIQUE="false" FIELDS="quizid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
