{
  "name": "uges-moodle-qa",
  "version": "1.0.0",
  "description": "Suite E2E automatizada del módulo de exámenes de Moodle (Playwright + TypeScript). Prueba Técnica 2 — GES.",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.6.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:ci": "playwright test --reporter=html,github",
    "install:browsers": "pnpm dlx playwright install --with-deps chromium",
    "install:browsers:all": "pnpm dlx playwright install --with-deps",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "typescript": "^7.0.2",
    "dotenv": "^17.4.2"
  },
  "keywords": [
    "playwright",
    "e2e",
    "moodle",
    "qa-automation",
    "typescript"
  ],
  "author": "",
  "license": "UNLICENSED"
}
