# --- Sitio ---
# SITE_URL debe coincidir con MOODLE_PORT: se fija como $CFG->wwwroot en la instalación.
MOODLE_PORT=8080
SITE_URL=http://localhost:8080
# Sin espacios: el instalador de la imagen pasa el valor sin comillas al CLI de Moodle (hallazgo 2026-07-11)
MOODLE_SITENAME=QA-EXAMS-Lab
MOODLE_LANGUAGE=en

# --- Admin Moodle ---
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=Admin123!
MOODLE_ADMIN_EMAIL=admin@example.com

# --- BD ---
DB_NAME=moodle
DB_USER=moodle
DB_PASS=moodlepass
DB_ROOT_PASS=rootpass

# --- Test users ---
TEACHER_USER=teacher1
TEACHER_PASS=Teacher123!
STUDENT1_USER=student1
STUDENT1_PASS=Student123!
STUDENT2_USER=student2
STUDENT2_PASS=Student123!

# --- Data ---
COURSE_SHORTNAME=QA-EXAMS-101
